algoritmo "calculadora"

var
    num1, num2: real

inicio

escreva("Digite o primeiro número: ")
leia(num1)

escreva("Digite o segundo número: ")
leia(num2)

escreval("Soma: ", num1 + num2)
escreval("Subtração: ", num1 - num2)
escreval("Multiplicação: ", num1 * num2)
escreval("Divisão: ", num1 / num2)

fimalgoritmo
